{
  "name": "shimba-wifi-backend",
  "version": "2.0.0",
  "description": "SHIMBA WiFi Backend — refactored with SQLite, TypeScript, rate limiting, JWT auth",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
